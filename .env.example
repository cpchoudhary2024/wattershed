# Wattershed runs fully keyless by default — every required data source is
# either a public bulk file or an unauthenticated API.
#
# The variables below unlock OPTIONAL enrichments. Copy this file to `.env`
# and fill in only what you want. All listed keys are free (no credit card).

# EIA Open Data API v2 — optional: recent balancing-authority generation mix
# and demand trends (fresher than eGRID's annual snapshot).
# Register (free, instant): https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# U.S. Census Bureau API — optional: only needed if you re-run the national
# reference build via the live API instead of the default keyless bulk
# summary files. Register (free): https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
